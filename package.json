{
  "name": "faxdrop-mcp",
  "version": "0.1.6",
  "description": "Send real faxes from any MCP-enabled AI assistant. Wraps the FaxDrop API (PDF/DOCX/JPG/PNG, international numbers, status polling) with rate limits, dry-run mode, and audit logging.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "faxdrop",
    "fax",
    "fax-api",
    "ai",
    "llm",
    "claude",
    "anthropic",
    "agent-tools"
  ],
  "homepage": "https://github.com/klodr/faxdrop-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klodr/faxdrop-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/klodr/faxdrop-mcp/issues"
  },
  "license": "MIT",
  "author": "klodr",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "faxdrop-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "test": "jest",
    "version": "node scripts/sync-version.mjs && git add server.json src/server.ts",
    "prepublishOnly": "NODE_ENV=production npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2"
  },
  "overrides": {
    "test-exclude": "^8.0.0"
  }
}
