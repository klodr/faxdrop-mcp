{
  "name": "faxdrop-mcp",
  "version": "0.3.8",
  "description": "Send real faxes from any MCP-enabled AI assistant. Wraps the FaxDrop API (PDF/DOCX/JPG/PNG, international numbers, status polling) with rate limits, dry-run mode, and audit logging.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "faxdrop",
    "fax",
    "fax-api",
    "ai",
    "llm",
    "claude",
    "anthropic",
    "agent-tools"
  ],
  "homepage": "https://github.com/klodr/faxdrop-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klodr/faxdrop-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/klodr/faxdrop-mcp/issues"
  },
  "license": "MIT",
  "author": "klodr",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "faxdrop-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "test": "vitest run",
    "version": "node scripts/sync-version.mjs && git add server.json src/server.ts",
    "prepublishOnly": "NODE_ENV=production npm run build",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "libphonenumber-js": "^1.12.41",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "test-exclude": "^8.0.0"
  }
}
