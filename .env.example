FAXDROP_API_KEY=fd_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override base URL (e.g. for a self-hosted proxy or testing)
# FAXDROP_API_BASE_URL=https://www.faxdrop.com

# --- Safeguards (all optional) ---

# Dry-run: write tools (faxdrop_send_fax, faxdrop_pair_number) return the
# would-be payload (sensitive fields redacted) without calling FaxDrop or
# touching paired.json. Reads still pass through.
# FAXDROP_MCP_DRY_RUN=true

# Append-only audit log of every write call (file mode 0o600, sensitive
# fields redacted). Must be an absolute path.
# FAXDROP_MCP_AUDIT_LOG=/abs/path/audit.log

# --- Phone-number gate (3 layers) ---

# Per-number policy. Default: pairing (HITL approve-by-default).
#   open    → any number that passed TYPE+COUNTRY is allowed
#   pairing → number must be in paired.json (added via faxdrop_pair_number)
#   closed  → number must be in paired.json; runtime pairing disabled
# FAXDROP_MCP_NUMBER_GATE=pairing

# Allowed phone TYPES (libphonenumber NumberType). Default below.
# FAXDROP_MCP_ALLOWED_TYPES=FIXED_LINE,FIXED_LINE_OR_MOBILE,VOIP,TOLL_FREE

# Allowed COUNTRY codes (ISO-3166-1 alpha-2). Default = US/CA + US territories.
# FAXDROP_MCP_ALLOWED_COUNTRIES=US,CA,PR,GU,VI,AS,MP

# --- File-path jail ---

# Outbox directory: every uploaded document must live inside this dir.
# Default: ~/FaxOutbox/ (auto-created mode 0o700). Must be an absolute path.
# FAXDROP_MCP_WORK_DIR=/Users/you/FaxOutbox

# State directory for paired.json (and any future per-user state).
# Default: ~/.faxdrop-mcp/ (auto-created mode 0o700). Must be absolute.
# FAXDROP_MCP_STATE_DIR=/Users/you/.faxdrop-mcp
